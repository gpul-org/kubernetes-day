---
import { RSVPForm } from '../components/RSVPForm';
import { RSVPCount } from '../components/RSVPCount';
import type { ImageMetadata } from 'astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import acoruna from '../assets/acoruna.png';
import aesia from '../assets/aesia.png';
import aojea from '../assets/aojea.jpg';
import cncfGalicia from '../assets/cncf-galicia.jpg';
import csanchez from '../assets/csanchez.jpg';
import dmellado from '../assets/dmellado.jpg';
import gdgCoruna from '../assets/gdg-coruna.png';
import gpul from '../assets/gpul.svg';
import k8s from '../assets/k8s.svg';
import kelea from '../assets/kelea.svg';
import sysarmyGalicia from '../assets/sysarmy-galicia.png';

interface Speaker {
  name: string;
  role: string;
  image: ImageMetadata;
  linkedin: string;
}

interface AgendaItem {
  time: string;
  title: string;
  text: string;
  speakers?: Speaker[];
  logo?: ImageMetadata;
}

const agenda: AgendaItem[] = [
  {
    time: '18:30 – 18:45',
    title: 'Bienvenida y apertura',
    text: 'Arranque de la jornada y presentación del enfoque del encuentro.'
  },
  {
    time: '18:45 – 20:15',
    title: 'Charlas técnicas',
    text: 'Bloque de charlas sobre infraestructura cloud native, despliegue de IA y operación de sistemas en producción.',
    speakers: [
      {
        name: 'Antonio Ojea',
        role: 'Senior Staff Engineer @ Google, Steering Comittee Kubernetes.',
        image: aojea,
        linkedin: 'https://www.linkedin.com/in/ajojea/'
      },
      {
        name: 'Carlos Sánchez',
        role: 'Principal Scientist at Adobe, Member at the Apache Software Foundation.',
        image: csanchez,
        linkedin: 'https://www.linkedin.com/in/carlossg/'
      },
      {
        name: 'Daniel Mellado',
        role: 'Principal Software Engineer at Red Hat.',
        image: dmellado,
        linkedin: 'https://www.linkedin.com/in/danielmelladoarea/'
      }
    ]
  },
  {
    time: '20:15 – 21:00',
    title: 'Mesa redonda: IA Responsable y Cloud Native',
    text: 'Conversación sobre regulación, supervisión y el impacto de estas decisiones en el trabajo técnico.'
  },
  {
    time: '21:00 – 22:00',
    title: 'Networking con cena',
    text: 'Cierre de la jornada con catering y tiempo para conversar con el resto de asistentes.',
    logo: kelea
  }
];

const goals = [
  'Escuchar una conversación práctica sobre cómo llevar IA a producción sobre infraestructura cloud native.',
  'Entender mejor cómo afectan la regulación y la supervisión al trabajo técnico diario.',
  'Compartir la tarde con perfiles de comunidad, empresa e instituciones en un formato pensado para conversar con calma.'
];

const entities = [
  {
    label: 'Organizan',
    items: [
      { alt: 'Logotipo de GDG A Coruña', className: 'logo-image--gdg', logo: gdgCoruna, shape: 'wide', url: 'https://gdg.community.dev/gdg-a-coruna/' },
      { alt: 'Logotipo de GPUL', className: 'logo-image--gpul', logo: gpul, shape: 'square', url: 'https://gpul.org' }
    ]
  },
  {
    label: 'Patrocina',
    items: [{ alt: 'Logotipo de Kelea', className: 'logo-image--kelea', logo: kelea, shape: 'wide', url: 'https://kelea.es' }]
  },
  {
    label: 'Colaboran',
    items: [
      { alt: 'Logotipo de AESIA', className: 'logo-image--aesia', logo: aesia, shape: 'wide', url: 'https://aesia.digital.gob.es' },
      { alt: 'Logotipo do Concello da Coruña', className: 'logo-image--acoruna', logo: acoruna, shape: 'wide', url: 'https://www.coruna.gal' },
      { alt: 'Logotipo de CNCF Galicia', className: 'logo-image--cncf', logo: cncfGalicia, shape: 'square', url: 'https://community.cncf.io/cloud-native-galicia/' },
      { alt: 'Logotipo de Sysarmy Galicia', className: 'logo-image--sysarmy', logo: sysarmyGalicia, shape: 'wide', url: 'https://sysarmy.galicia.dev/' }
    ]
  }
];

const trustLogos = [
  { alt: 'Logotipo de Kubernetes', className: 'logo-image--k8s', logo: k8s, shape: 'square', url: 'https://kubernetes.io' },
  { alt: 'Logotipo de GPUL', className: 'logo-image--gpul', logo: gpul, shape: 'square', url: 'https://gpul.org' },
  { alt: 'Logotipo de GDG A Coruña', className: 'logo-image--gdg', logo: gdgCoruna, shape: 'wide', url: 'https://gdg.community.dev/gdg-a-coruna/' },
  { alt: 'Logotipo de Kelea', className: 'logo-image--kelea', logo: kelea, shape: 'wide', url: 'https://kelea.es' },
  { alt: 'Logotipo de AESIA', className: 'logo-image--aesia', logo: aesia, shape: 'wide', url: 'https://aesia.digital.gob.es' },
  { alt: 'Logotipo do Concello da Coruña', className: 'logo-image--acoruna', logo: acoruna, shape: 'wide', url: 'https://www.coruna.gal' },
  { alt: 'Logotipo de CNCF Galicia', className: 'logo-image--cncf', logo: cncfGalicia, shape: 'square', url: 'https://community.cncf.io/cloud-native-galicia/' },
  { alt: 'Logotipo de Sysarmy Galicia', className: 'logo-image--sysarmy', logo: sysarmyGalicia, shape: 'wide', url: 'https://sysarmy.galicia.dev/' }
];

function getLogoSrc(logo: typeof gdgCoruna | typeof gpul) {
  return typeof logo === 'string' ? logo : logo.src;
}

function getLogoContainerClasses(className: string) {
  const base = "flex items-center justify-center border-2 border-black bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] h-24 overflow-hidden transition-all duration-200";
  return `${base} p-4`;
}

function getLogoImageClasses(className: string) {
  const base = "logo-image grayscale contrast-125 hover:grayscale-0 transition-all h-full w-full object-contain";
  if (className === 'logo-image--aesia') return "logo-image w-full h-full object-contain grayscale contrast-125 hover:grayscale-0 scale-110 hover:scale-100 transition-all duration-500";
  if (className === 'logo-image--cncf') return `${base} scale-125`;
  if (className === 'logo-image--kelea') return `${base} scale-110`;
  if (className === 'logo-image--gdg') return `${base} scale-[1.9] hover:scale-[1.75]`;
  if (className === 'logo-image--gpul') return `${base} p-0 scale-110`;
  if (className === 'logo-image--sysarmy') return `${base} scale-125`;
  return base;
}
---

<BaseLayout
  title="Kubernetes & AI, con sentidiño"
  description="Evento técnico en A Coruña sobre Kubernetes, IA responsable y comunidad. Reserva tu plaza para la jornada organizada por GDG A Coruña y GPUL."
>
  <main>
    <section class="mx-auto max-w-4xl px-4 py-12 md:py-24">
      <div class="border-4 border-black bg-white p-6 shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] md:p-12">
        <nav class="mb-16 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div class="flex items-center gap-4">
            <img alt="Kubernetes" class="h-10 w-auto" src={getLogoSrc(k8s)} />
            <div class="border-l-4 border-black pl-4">
              <p class="text-lg font-black uppercase tracking-tighter">Kubernetes & AI</p>
              <p class="text-sm font-bold uppercase tracking-widest text-zinc-500">A Coruña · 2026</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 text-sm font-black uppercase tracking-widest">
            <a class="border-2 border-black bg-white px-4 py-2 hover:bg-yellow-300 transition-colors" href="#agenda">Agenda</a>
            <a class="border-2 border-black bg-white px-4 py-2 hover:bg-yellow-300 transition-colors" href="#entidades">Entidades</a>
            <a class="border-2 border-black bg-black text-white px-4 py-2 hover:bg-blue-600 transition-colors" href="#rsvp">RSVP</a>
          </div>
        </nav>

        <div class="space-y-12">
          <div class="space-y-8">
            <div class="flex flex-wrap items-center gap-3">
              <span class="border-2 border-black bg-yellow-300 px-3 py-1 text-xs font-black uppercase shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] tracking-widest">Miércoles, 13 de mayo de 2026</span>
              <span class="border-2 border-black bg-blue-400 px-3 py-1 text-xs font-black uppercase shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] tracking-widest text-white">18:30 – 22:00</span>
              <span class="border-2 border-black bg-white px-3 py-1 text-xs font-black uppercase shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] tracking-widest">Centro Ágora · A Coruña</span>
            </div>
            <h1 class="text-5xl font-black uppercase leading-[0.85] tracking-tighter md:text-8xl">
              Kubernetes & AI, <span class="italic text-[0.8em]">con sentidiño</span>
            </h1>
            <p class="max-w-2xl text-xl font-medium leading-tight md:text-2xl">
              Un encuentro técnico en A Coruña para hablar de Kubernetes, IA en producción y supervisión responsable, con charlas, mesa redonda y una cena final.
            </p>
            <div class="pt-4">
              <RSVPCount client:load />
            </div>

            <div class="flex flex-col gap-6 pt-8 md:flex-row">
              <a class="flex-1 border-4 border-black bg-blue-600 px-8 py-6 text-2xl font-black uppercase text-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all active:translate-y-0 active:shadow-none text-center" href="#rsvp">
                Reservar plaza
              </a>
              <a class="flex-1 border-4 border-black bg-white px-8 py-6 text-2xl font-black uppercase text-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] transition-all active:translate-y-0 active:shadow-none text-center" href="#agenda">
                Ver programa
              </a>
            </div>
          </div>

          <div class="border-t-4 border-black pt-8">
            <p class="mb-6 text-sm font-black uppercase tracking-widest text-zinc-500">
              Organizan, patrocinan y colaboran
            </p>
              <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                {trustLogos.filter(item => item.className !== 'logo-image--k8s').map((item) => (
                  <a 
                    href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class={`${getLogoContainerClasses(item.className)} hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] active:translate-y-0 active:shadow-none transition-all`}
                >
                  <img
                    alt={item.alt}
                    class={getLogoImageClasses(item.className)}
                    loading="lazy"
                    src={getLogoSrc(item.logo)}
                  />
                </a>
              ))}
            </div>
          </div>

          <div class="border-t-4 border-black">
            <div class="grid gap-0 md:grid-cols-3">
              <div class="border-black p-6 md:border-r-4">
                <p class="text-xs font-black uppercase tracking-widest text-zinc-500">Aforo</p>
                <p class="mt-2 text-3xl font-black uppercase tracking-tighter">80 plazas</p>
              </div>
              <div class="border-black p-6 md:border-r-4">
                <p class="text-xs font-black uppercase tracking-widest text-zinc-500">Formato</p>
                <p class="mt-2 text-3xl font-black uppercase tracking-tighter">Charlas + Cena</p>
              </div>
              <div class="p-6">
                <p class="text-xs font-black uppercase tracking-widest text-zinc-500">Enfoque</p>
                <p class="mt-2 text-3xl font-black uppercase tracking-tighter">Kubernetes + IA</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-16 md:py-24">
      <div class="grid gap-12 md:grid-cols-[1fr_1.2fr] md:items-start">
        <div class="max-w-sm">
          <SectionHeading
            eyebrow="Por qué asistir"
            title="Una tarde de producción"
            text="El programa está pensado para perfiles técnicos que quieren entender mejor cómo se cruzan la infraestructura, la IA y las decisiones de supervisión."
          />
        </div>

        <div class="border-4 border-black bg-white p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
          <ul class="space-y-8 text-lg font-bold leading-tight">
            {goals.map((goal) => (
              <li class="flex gap-4">
                <span class="mt-1 h-6 w-6 shrink-0 border-4 border-black bg-yellow-300"></span>
                <span>{goal}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section id="agenda" class="mx-auto max-w-4xl px-4 py-16 md:py-24">
      <div class="space-y-16">
        <SectionHeading
          eyebrow="Agenda"
          title="Así será la tarde"
          text="Un formato sencillo: bienvenida, bloque de charlas, mesa redonda y cierre con cena para seguir conversando."
        />

        <div class="border-4 border-black bg-white shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] divide-y-4 divide-black">
          {agenda.map((item) => (
            <article class="grid gap-8 p-8 md:grid-cols-[220px_1fr]">
              <div>
                <p class="inline-block bg-blue-600 px-3 py-1 text-sm font-black uppercase tracking-widest text-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                  {item.time}
                </p>
              </div>
              <div class="space-y-4">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                  <h3 class="text-3xl font-black uppercase leading-none tracking-tighter text-black md:text-4xl">
                    {item.title}
                  </h3>
                  {item.logo && (
                    <div class="flex items-center gap-3 border-2 border-black bg-yellow-300 px-3 py-1 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] rotate-[-1deg] w-fit">
                      <span class="text-[10px] font-black uppercase tracking-tighter text-black">Ofrecido por</span>
                      <img src={item.logo.src} alt="Kelea" class="h-6 w-auto" />
                    </div>
                  )}
                </div>
                <p class="text-lg font-medium leading-relaxed text-zinc-700">{item.text}</p>
                {item.speakers && (
                  <div class="grid gap-6 pt-4 sm:grid-cols-2 lg:grid-cols-3">
                    {item.speakers.map((speaker) => (
                      <a 
                        href={speaker.linkedin} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="group flex flex-col border-4 border-black bg-white p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 transition-all"
                      >
                        <div class="mb-4 aspect-square overflow-hidden border-4 border-black">
                          <img 
                            src={speaker.image.src} 
                            alt={speaker.name}
                            class="h-full w-full object-cover grayscale transition-all group-hover:grayscale-0"
                          />
                        </div>
                        <h4 class="text-xl font-black uppercase leading-[0.9] tracking-tighter">
                          {speaker.name}
                        </h4>
                        <p class="mt-2 text-sm font-bold leading-snug text-zinc-600">
                          {speaker.role}
                        </p>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="entidades" class="mx-auto max-w-4xl px-4 py-16 md:py-24">
      <div class="space-y-16">
        <div class="max-w-2xl">
          <SectionHeading
            eyebrow="Entidades participantes"
            title="Quién está detrás"
            text="El encuentro está impulsado por comunidad técnica, empresa e instituciones vinculadas al debate sobre IA y su aplicación real."
          />
        </div>

        <div class="space-y-8">
          {entities.map((group) => (
            <article class="border-4 border-black bg-white p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
              <div class="flex flex-col gap-8 md:flex-row md:items-center">
                <p class="inline-block bg-black px-3 py-1 text-sm font-black uppercase tracking-[0.2em] text-white shrink-0">
                  {group.label}
                </p>
                <ul class="grid flex-1 gap-4 sm:grid-cols-2">
                {group.items.map((item) => (
                  <a 
                    href={item.url} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class={`${getLogoContainerClasses(item.className)} border-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all`}
                  >
                    <img
                      alt={item.alt}
                      class={getLogoImageClasses(item.className)}
                      loading="lazy"
                      src={getLogoSrc(item.logo)}
                    />
                  </a>
                ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="rsvp" class="mx-auto max-w-4xl px-4 py-16 pb-32">
      <div class="grid gap-12 md:grid-cols-[0.82fr_1.18fr] md:items-start">
        <div class="max-w-sm">
          <SectionHeading
            eyebrow="Reserva"
            title="Aforo limitado"
            text="La asistencia requiere inscripción previa. Solo te pediremos los datos necesarios para confirmar tu plaza y organizar el catering."
          />

          <div class="mt-12 border-4 border-black bg-yellow-300 p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
            <p class="text-lg font-black uppercase tracking-widest text-black">Detalles clave</p>
            <ul class="mt-6 space-y-4 text-base font-bold leading-tight">
              <li class="flex gap-2"><span>•</span> <span>Miércoles, 13 de mayo de 2026</span></li>
              <li class="flex gap-2"><span>•</span> <span>18:30 – 22:00</span></li>
              <li class="flex gap-2"><span>•</span> <span>Centro Ágora, A Coruña</span></li>
              <li class="flex gap-2"><span>•</span> <span>Cena networking (ofrecida por Kelea)</span></li>
            </ul>
          </div>
        </div>

        <RSVPForm client:load />
      </div>
    </section>
  </main>
</BaseLayout>
