---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
}

const { eyebrow, text, title } = Astro.props;
---

<div class="max-w-2xl space-y-6">
  <p class="inline-block bg-black px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-white">
    {eyebrow}
  </p>
  <h2 class="text-4xl font-black uppercase leading-[0.9] tracking-tighter text-black md:text-6xl">{title}</h2>
  {text && <p class="max-w-xl text-lg font-medium leading-relaxed text-zinc-700 md:text-xl">{text}</p>}
</div>
